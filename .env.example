# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/sign-up

# Neon Postgres
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Vercel Blob — auto-set by `vercel env pull`. Required for /admin/editor uploads.
BLOB_READ_WRITE_TOKEN=

# fal.ai — image generation (Seedream + Nano Banana Pro)
FAL_API_KEY=

# Google Generative AI — Gemini 2.5 Pro multimodal QA
GEMINI_API_KEY=

# Dropbox app credentials — see docs/dropbox-setup.md
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Cron auth — Vercel Cron sends this header on invocations
CRON_SECRET=
